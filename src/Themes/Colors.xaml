<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Monochrome "Avallon" palette ============ -->
    <!-- Near-black canvas with a subtle vertical fade, hairline borders,
         a light (white) accent for primary actions & toggles. No color. -->

    <Color x:Key="Canvas">#0A0A0C</Color>
    <Color x:Key="CanvasTop">#111114</Color>
    <Color x:Key="CanvasBottom">#070709</Color>
    <Color x:Key="Surface">#0F0F12</Color>
    <Color x:Key="SurfaceAlt">#151519</Color>
    <Color x:Key="Elevated">#1A1A1F</Color>
    <Color x:Key="ElevatedHover">#212127</Color>
    <Color x:Key="Hairline">#1E1E23</Color>
    <Color x:Key="HairlineStrong">#2C2C33</Color>

    <Color x:Key="TextPrimary">#F4F4F6</Color>
    <Color x:Key="TextSecondary">#9C9CA6</Color>
    <Color x:Key="TextMuted">#5C5C66</Color>

    <!-- Accent is now light/neutral (white-ish) — matches the reference. -->
    <Color x:Key="Accent">#F2F2F5</Color>
    <Color x:Key="AccentHover">#FFFFFF</Color>
    <Color x:Key="AccentPressed">#DADADE</Color>
    <Color x:Key="AccentSoft">#1C1C22</Color>
    <Color x:Key="OnAccent">#0A0A0C</Color>

    <Color x:Key="Success">#4ADE80</Color>
    <Color x:Key="Warning">#E3B341</Color>
    <Color x:Key="Danger">#F87171</Color>
    <Color x:Key="DangerSoft">#241618</Color>
    <Color x:Key="Info">#93B4E8</Color>

    <!-- ============ Brushes ============ -->
    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource Canvas}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAlt}" />
    <SolidColorBrush x:Key="ElevatedBrush" Color="{StaticResource Elevated}" />
    <SolidColorBrush x:Key="ElevatedHoverBrush" Color="{StaticResource ElevatedHover}" />
    <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource Hairline}" />
    <SolidColorBrush x:Key="HairlineStrongBrush" Color="{StaticResource HairlineStrong}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressed}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccent}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoft}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}" />

    <!-- Window backdrop: subtle top-to-bottom fade -->
    <LinearGradientBrush x:Key="WindowBackdropBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="{StaticResource CanvasTop}" Offset="0" />
        <GradientStop Color="{StaticResource Canvas}" Offset="0.35" />
        <GradientStop Color="{StaticResource CanvasBottom}" Offset="1" />
    </LinearGradientBrush>

    <!-- Specular highlight across the top edge of the window -->
    <LinearGradientBrush x:Key="TopSheenBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00FFFFFF" Offset="0" />
        <GradientStop Color="#26FFFFFF" Offset="0.28" />
        <GradientStop Color="#66FFFFFF" Offset="0.5" />
        <GradientStop Color="#26FFFFFF" Offset="0.72" />
        <GradientStop Color="#00FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <!-- Soft glow just under the sheen -->
    <LinearGradientBrush x:Key="TopGlowBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#14FFFFFF" Offset="0" />
        <GradientStop Color="#00FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <!-- ============ Type scale ============ -->
    <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, monospace</FontFamily>

    <!-- ============ Radii & metrics ============ -->
    <CornerRadius x:Key="RadiusSm">7</CornerRadius>
    <CornerRadius x:Key="RadiusMd">10</CornerRadius>
    <CornerRadius x:Key="RadiusLg">14</CornerRadius>
    <CornerRadius x:Key="RadiusXl">18</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <DropShadowEffect x:Key="ShadowSoft" BlurRadius="34" ShadowDepth="10"
                      Direction="270" Opacity="0.5" Color="#000000" />

</ResourceDictionary>
