<Window x:Class="RobloxAccountManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:mvvm="clr-namespace:RobloxAccountManager.Mvvm"
        xmlns:views="clr-namespace:RobloxAccountManager.Views"
        xmlns:ram="clr-namespace:RobloxAccountManager"
        Title="Roblox Account Manager"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="1180" Height="760" MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CanvasBrush}"
        WindowStyle="None"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="{StaticResource UiFont}">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <mvvm:IndexToVis x:Key="IndexToVis" />
        <mvvm:HexToBrush x:Key="HexToBrush" />
    </Window.Resources>

    <Border x:Name="RootBorder" Background="{DynamicResource WindowBackdropBrush}"
            BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1"
            TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
            TextElement.FontFamily="{StaticResource UiFont}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ==================== NAV RAIL ==================== -->
            <Border Grid.Column="0" Background="Transparent"
                    BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Brand -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="22,24,20,28">
                        <Grid Width="40" Height="40">
                            <Border CornerRadius="12" Background="{DynamicResource ElevatedBrush}"
                                    BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1" />
                            <Image Width="30" Height="30"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Source>
                                    <BitmapImage UriSource="pack://application:,,,/Assets/app.ico" DecodePixelWidth="64" />
                                </Image.Source>
                            </Image>
                        </Grid>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Account Manager" FontWeight="SemiBold" FontSize="13.5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="ROBLOX" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Nav -->
                    <StackPanel Grid.Row="1" Margin="14,0">
                        <TextBlock Text="MENU" FontSize="10.5" FontWeight="SemiBold" Margin="12,0,0,10"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <ItemsControl ItemsSource="{Binding NavItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Cursor="Hand" Margin="0,2" HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.NavCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Index}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="9" Padding="11,10" Background="Transparent">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border x:Name="pill" Width="3" Height="18" CornerRadius="2"
                                                                HorizontalAlignment="Left" Margin="-11,0,0,0"
                                                                Background="{DynamicResource AccentBrush}" Opacity="0" />
                                                        <Path x:Name="ic" Grid.Column="0" Width="19" Height="19"
                                                              Data="{Binding IconKey, Converter={StaticResource IconKeyConverter}}"
                                                              Style="{StaticResource IconPath}" />
                                                        <TextBlock x:Name="tx" Grid.Column="1" Text="{Binding Title}"
                                                                   Margin="12,0,0,0" VerticalAlignment="Center"
                                                                   FontSize="13" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                        <Setter TargetName="tx" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                        <Setter TargetName="ic" Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource ElevatedBrush}" />
                                                        <Setter TargetName="tx" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                        <Setter TargetName="tx" Property="FontWeight" Value="SemiBold" />
                                                        <Setter TargetName="ic" Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
                                                        <Setter TargetName="pill" Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Footer: status -->
                    <Border Grid.Row="2" Margin="16,0,16,16" Padding="14,12" Style="{StaticResource Card}"
                            Background="{DynamicResource SurfaceBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Status" Margin="8,0,0,0" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" FontWeight="Medium" />
                            </StackPanel>
                            <TextBlock Text="{Binding Status}" Margin="0,6,0,0" FontSize="12"
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ==================== MAIN AREA ==================== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Grid Grid.Row="0" Background="Transparent">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="26,0,0,0">
                        <TextBlock Text="Roblox Account Manager" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
                        <Border CornerRadius="6" Padding="7,2" Margin="12,0,0,0" VerticalAlignment="Center"
                                Background="{DynamicResource SurfaceAltBrush}">
                            <TextBlock Text="{Binding AppVersionShort}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <!-- Self-update pill: only shown when a newer GitHub release was found -->
                        <Button Margin="12,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Command="{Binding UpdateNowCommand}"
                                ToolTip="Download and install the update"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6" Padding="9,3"
                                            Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="ic" Data="{StaticResource Icon.Import}"
                                                  Style="{StaticResource IconPath}" Width="11" Height="11"
                                                  Stroke="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock x:Name="tx" Text="{Binding UpdateVersionText}" Margin="6,0,0,0"
                                                       FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource ElevatedBrush}" />
                                            <Setter TargetName="tx" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                            <Setter TargetName="ic" Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click" ToolTip="Minimize">
                            <Path Data="{StaticResource Icon.Minimize}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                        </Button>
                        <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Click="Maximize_Click" ToolTip="Maximize">
                            <Path Data="{StaticResource Icon.Maximize}" Style="{StaticResource IconPath}" Width="13" Height="13" />
                        </Button>
                        <Button Style="{StaticResource CloseCaptionButton}" Click="Close_Click" ToolTip="Close">
                            <Path Data="{StaticResource Icon.Close}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Pages -->
                <Grid Grid.Row="1">
                    <views:AccountsPage DataContext="{Binding Accounts}" Style="{StaticResource PageTransition}"
                                        Visibility="{Binding DataContext.SelectedIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource IndexToVis}, ConverterParameter=1}">
                        <views:AccountsPage.RenderTransform><TranslateTransform /></views:AccountsPage.RenderTransform>
                    </views:AccountsPage>
                    <views:ServerBrowserPage DataContext="{Binding Servers}" Style="{StaticResource PageTransition}"
                                        Visibility="{Binding DataContext.SelectedIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource IndexToVis}, ConverterParameter=3}">
                        <views:ServerBrowserPage.RenderTransform><TranslateTransform /></views:ServerBrowserPage.RenderTransform>
                    </views:ServerBrowserPage>
                    <views:SettingsPage DataContext="{Binding Settings}" Style="{StaticResource PageTransition}"
                                        Visibility="{Binding DataContext.SelectedIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource IndexToVis}, ConverterParameter=4}">
                        <views:SettingsPage.RenderTransform><TranslateTransform /></views:SettingsPage.RenderTransform>
                    </views:SettingsPage>
                    <views:DashboardPage DataContext="{Binding Dashboard}" Style="{StaticResource PageTransition}"
                                        Visibility="{Binding DataContext.SelectedIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource IndexToVis}, ConverterParameter=0}">
                        <views:DashboardPage.RenderTransform><TranslateTransform /></views:DashboardPage.RenderTransform>
                    </views:DashboardPage>
                    <views:FriendsPage DataContext="{Binding Friends}" Style="{StaticResource PageTransition}"
                                        Visibility="{Binding DataContext.SelectedIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource IndexToVis}, ConverterParameter=2}">
                        <views:FriendsPage.RenderTransform><TranslateTransform /></views:FriendsPage.RenderTransform>
                    </views:FriendsPage>
                </Grid>
            </Grid>

            <!-- ==================== TOP SHEEN (premium light edge) ==================== -->
            <Grid Grid.ColumnSpan="2" VerticalAlignment="Top" Height="64" IsHitTestVisible="False">
                <Border Height="64" VerticalAlignment="Top" Background="{StaticResource TopGlowBrush}" Opacity="0.6" />
                <Border Height="1.4" VerticalAlignment="Top" Background="{StaticResource TopSheenBrush}" />
            </Grid>

            <!-- ==================== TOAST OVERLAY (#30) ==================== -->
            <ItemsControl Grid.ColumnSpan="2" ItemsSource="{Binding Toasts}"
                          VerticalAlignment="Top" HorizontalAlignment="Right"
                          Margin="0,52,18,0" Width="340" Panel.ZIndex="99">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource ElevatedBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1"
                                Margin="0,0,0,10" Effect="{StaticResource ShadowSoft}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- accent bar keyed on the toast kind -->
                                <Border Grid.Column="0" CornerRadius="10,0,0,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="Success">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,11,8,11">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Message}" Style="{StaticResource Caption}"
                                               Margin="0,3,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding HasMessage, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                                <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                        Command="{Binding DismissCommand}" ToolTip="Dismiss"
                                        VerticalAlignment="Top" HorizontalAlignment="Right"
                                        Width="26" Height="26" Padding="0" Margin="0,6,6,0">
                                    <Path Data="{StaticResource Icon.Close}" Style="{StaticResource IconPath}"
                                          Width="11" Height="11" Stretch="Uniform" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>
