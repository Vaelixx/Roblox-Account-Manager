<UserControl x:Class="RobloxAccountManager.Views.AccountsPage"
             PreviewKeyDown="OnPreviewKeyDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:data="clr-namespace:System.Windows.Data;assembly=PresentationFramework"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:models="clr-namespace:RobloxAccountManager.Models">

    <UserControl.Resources>
        <CollectionViewSource x:Key="GroupedAccounts" Source="{Binding Store.Accounts}"
                              IsLiveSortingRequested="True">
            <CollectionViewSource.GroupDescriptions>
                <data:PropertyGroupDescription PropertyName="Group" />
            </CollectionViewSource.GroupDescriptions>
            <!-- Group asc keeps buckets contiguous; then pinned (favorite) rows float to the
                 top of each group, remaining rows alphabetical. -->
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Group" Direction="Ascending" />
                <scm:SortDescription PropertyName="IsFavorite" Direction="Descending" />
                <scm:SortDescription PropertyName="DisplayNameOrUser" Direction="Ascending" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <!-- Icon-sized toggle for the saved-places dropdown (mirrors IconButton). -->
        <Style x:Key="IconToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" CornerRadius="{StaticResource RadiusSm}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ElevatedHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Left-aligned menu row for the saved-places popup. -->
        <Style x:Key="MenuRowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="{StaticResource RadiusSm}"
                                Background="{TemplateBinding Background}" Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ElevatedHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
                                <DataTemplate x:Key="AccountCardTemplate" DataType="{x:Type models:Account}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Multi-select tick -->
                                        <CheckBox Grid.Column="0" Style="{StaticResource SelectCheck}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <!-- Avatar -->
                                        <Grid Grid.Column="1" Width="42" Height="42">
                                            <Border CornerRadius="11" Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1" />
                                            <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <Border CornerRadius="11" ClipToBounds="True">
                                                <Image Source="{Binding ThumbnailUrl, Converter={StaticResource UrlToImage}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <Ellipse Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                     Margin="0,0,-2,-2" Fill="{Binding PresenceColor, Converter={StaticResource HexToBrush}}"
                                                     Stroke="{DynamicResource SurfaceBrush}" StrokeThickness="2" />
                                            <!-- Colour tag (#28): mirrors the presence dot, top-left -->
                                            <Ellipse Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top"
                                                     Margin="-2,-2,0,0" Fill="{Binding Color, Converter={StaticResource HexToBrush}}"
                                                     Stroke="{DynamicResource SurfaceBrush}" StrokeThickness="2"
                                                     Visibility="{Binding HasColor, Converter={StaticResource BoolToVis}}" />
                                        </Grid>

                                        <!-- Name / meta -->
                                        <StackPanel Grid.Column="2" Margin="13,0" VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" FontSize="13.5" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource MaskConverter}">
                                                        <Binding Path="DisplayNameOrUser" />
                                                        <Binding Path="DataContext.MaskUsernames" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding Presence}" FontSize="11"
                                                           Foreground="{Binding PresenceColor, Converter={StaticResource HexToBrush}}" />
                                                <Border Margin="5,0,0,0" Padding="4,0" CornerRadius="3" VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentBrush}" ToolTip="{Binding SubPlaceTip}"
                                                        Visibility="{Binding IsSubPlace, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="SUB" FontSize="9" FontWeight="Bold" Foreground="White" />
                                                </Border>
                                                <TextBlock Text="•" FontSize="11" Margin="6,0" Foreground="{DynamicResource TextMutedBrush}" />
                                                <Path Data="{StaticResource Icon.Robux}" Stroke="{DynamicResource TextMutedBrush}"
                                                      StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding RobuxDisplay}" FontSize="11" Margin="4,0,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <TextBlock Text="{Binding Username, StringFormat='@{0}'}" FontSize="11" Margin="8,0,0,0"
                                                           Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding Alias, Converter={StaticResource NullToVis}}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="11.5" Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Visibility="{Binding Description, Converter={StaticResource NullToVis}}" />
                                        </StackPanel>

                                        <Border Grid.Column="3" VerticalAlignment="Center" CornerRadius="6" Padding="7,3"
                                                Background="{DynamicResource DangerSoftBrush}"
                                                Visibility="{Binding IsValid, Converter={StaticResource InverseBoolToVis}}">
                                            <TextBlock Text="expired" FontSize="10" Foreground="{DynamicResource DangerBrush}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                        <DataTemplate x:Key="AccountCompactTemplate" DataType="{x:Type models:Account}">
                            <Border CornerRadius="6" Background="{DynamicResource SurfaceAltBrush}" Padding="6,2" Margin="0,1,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource SelectCheck}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Border Grid.Column="1" Width="20" Height="20" CornerRadius="10" ClipToBounds="True" Margin="6,0,0,0"
                                            Background="{DynamicResource SurfaceBrush}">
                                        <Image Source="{Binding ThumbnailUrl, Converter={StaticResource UrlToImage}}" Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"
                                               TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource MaskConverter}">
                                                <Binding Path="DisplayNameOrUser" />
                                                <Binding Path="DataContext.MaskUsernames" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Grid.Column="3" Text="{Binding RobuxDisplay}" Margin="8,0,0,0" VerticalAlignment="Center"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                    <Ellipse Grid.Column="4" Width="8" Height="8" Margin="8,0,4,0" VerticalAlignment="Center"
                                             Fill="{Binding PresenceColor, Converter={StaticResource HexToBrush}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="30,8,30,26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ==================== HERO ==================== -->
        <Grid Grid.Row="0" Margin="2,6,2,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="6" Height="6" Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="Accounts" Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
                <TextBlock Text="Your accounts" FontFamily="{StaticResource DisplayFont}" FontSize="34"
                           FontWeight="Normal" Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Margin="0,4,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding Store.Accounts.Count, StringFormat='{}{0} accounts saved · encrypted on this device'}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource IconButton}" Command="{Binding RefreshAllCommand}" ToolTip="Refresh data" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon.Refresh}" Style="{StaticResource IconPath}" />
                </Button>

                <!-- ==== #28 Colour-tag palette: applies to checked accounts (or the selected one) ==== -->
                <ToggleButton x:Name="ColourToggle" Margin="0,0,8,0" Cursor="Hand"
                              ToolTip="Colour-tag checked / selected accounts">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="bd" Width="40" Height="40" CornerRadius="10" Background="Transparent">
                                <Path Data="{StaticResource Icon.Bookmark}" Style="{StaticResource IconPath}"
                                      Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <Popup PlacementTarget="{Binding ElementName=ColourToggle}" Placement="Bottom" HorizontalOffset="-4"
                       StaysOpen="False" AllowsTransparency="True"
                       IsOpen="{Binding IsChecked, ElementName=ColourToggle, Mode=TwoWay}">
                    <Border Margin="6" Padding="8" CornerRadius="12"
                            Background="{DynamicResource ElevatedBrush}"
                            BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding SetColorCommand}" CommandParameter="#FF5C5C" ToolTip="Red" Width="24" Height="24" Margin="3,0" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button">
                                    <Ellipse Width="20" Height="20" Fill="#FF5C5C" Stroke="{DynamicResource HairlineStrongBrush}" StrokeThickness="1" />
                                </ControlTemplate></Button.Template>
                            </Button>
                            <Button Command="{Binding SetColorCommand}" CommandParameter="#FF9F40" ToolTip="Orange" Width="24" Height="24" Margin="3,0" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button">
                                    <Ellipse Width="20" Height="20" Fill="#FF9F40" Stroke="{DynamicResource HairlineStrongBrush}" StrokeThickness="1" />
                                </ControlTemplate></Button.Template>
                            </Button>
                            <Button Command="{Binding SetColorCommand}" CommandParameter="#F5C518" ToolTip="Gold" Width="24" Height="24" Margin="3,0" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button">
                                    <Ellipse Width="20" Height="20" Fill="#F5C518" Stroke="{DynamicResource HairlineStrongBrush}" StrokeThickness="1" />
                                </ControlTemplate></Button.Template>
                            </Button>
                            <Button Command="{Binding SetColorCommand}" CommandParameter="#4CD07D" ToolTip="Green" Width="24" Height="24" Margin="3,0" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button">
                                    <Ellipse Width="20" Height="20" Fill="#4CD07D" Stroke="{DynamicResource HairlineStrongBrush}" StrokeThickness="1" />
                                </ControlTemplate></Button.Template>
                            </Button>
                            <Button Command="{Binding SetColorCommand}" CommandParameter="#4C9AFF" ToolTip="Blue" Width="24" Height="24" Margin="3,0" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button">
                                    <Ellipse Width="20" Height="20" Fill="#4C9AFF" Stroke="{DynamicResource HairlineStrongBrush}" StrokeThickness="1" />
                                </ControlTemplate></Button.Template>
                            </Button>
                            <Button Command="{Binding SetColorCommand}" CommandParameter="#B57BFF" ToolTip="Purple" Width="24" Height="24" Margin="3,0" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button">
                                    <Ellipse Width="20" Height="20" Fill="#B57BFF" Stroke="{DynamicResource HairlineStrongBrush}" StrokeThickness="1" />
                                </ControlTemplate></Button.Template>
                            </Button>
                            <Border Width="1" Margin="6,2" Background="{DynamicResource HairlineStrongBrush}" />
                            <Button Command="{Binding ClearColorCommand}" ToolTip="Clear colour" Width="24" Height="24" Margin="3,0" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button">
                                    <Border x:Name="cb" CornerRadius="12" Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1">
                                        <Path Data="{StaticResource Icon.Close}" Style="{StaticResource IconPath}"
                                              Width="11" Height="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="cb" Property="Background" Value="{DynamicResource DangerBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate></Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>

                <Button Style="{StaticResource IconButton}" Command="{Binding FindDuplicatesCommand}" ToolTip="Find duplicate accounts (same username / user-id)" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon.Copy}" Style="{StaticResource IconPath}" />
                </Button>
                <Button Style="{StaticResource IconButton}" Command="{Binding ExportCommand}" ToolTip="Export accounts (checked, or all) to CSV / JSON" Margin="0,0,10,0">
                    <Path Data="{StaticResource Icon.External}" Style="{StaticResource IconPath}" />
                </Button>

                <Button Style="{StaticResource GhostButton}" Command="{Binding ImportCommand}" Height="40" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Import}" Style="{StaticResource IconPath}" Width="16" Height="16" />
                        <TextBlock Text="Import" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddCommand}" Height="40">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Plus}" Stroke="{DynamicResource OnAccentBrush}" StrokeThickness="2"
                              Width="16" Height="16" Stretch="Uniform"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        <TextBlock Text="Add account" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ==================== CONTENT ==================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: search + list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="Transparent"
                        BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="0,0,0,1.5"
                        Height="40" Margin="0,0,0,12">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Data="{StaticResource Icon.Search}" Style="{StaticResource IconPath}" Width="16" Height="16"
                              VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Margin="9,0,0,0">
                            <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Padding="0"
                                     Height="38" VerticalContentAlignment="Center" TextChanged="Search_Changed"
                                     KeyDown="SearchBox_KeyDown" />
                            <TextBlock Text="Search accounts…  (Ctrl+F)" IsHitTestVisible="False" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource InverseNullToVis}}" />
                        </Grid>
                        <!-- Live match count — only shown while a filter is active. -->
                        <TextBlock x:Name="ResultCount" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,4,0"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Visibility="Collapsed" />
                        <!-- Clear-search button (Esc also clears). -->
                        <Button x:Name="ClearSearchButton" Grid.Column="3" Style="{StaticResource IconButton}" Width="26" Height="26"
                                Click="ClearSearch_Click" ToolTip="Clear search (Esc)" VerticalAlignment="Center"
                                Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource NullToVis}}">
                            <Path Data="{StaticResource Icon.Close}" Style="{StaticResource IconPath}" Width="12" Height="12" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <ListView x:Name="AccountsList" ItemsSource="{Binding Source={StaticResource GroupedAccounts}}"
                                  SelectedItem="{Binding Selected, Mode=TwoWay}"
                                  SelectionMode="Extended" Background="Transparent" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="8"
                                  AllowDrop="True" Drop="AccountsList_Drop"
                                  MouseDoubleClick="AccountsList_MouseDoubleClick"
                                  PreviewMouseLeftButtonDown="AccountsList_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="AccountsList_PreviewMouseMove">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0,2" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="bd" CornerRadius="11" Padding="10"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource ElevatedBrush}" />
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource HairlineStrongBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.Style>
                                <Style TargetType="ListView">
                                    <Setter Property="ItemTemplate" Value="{StaticResource AccountCardTemplate}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                            <Setter Property="ItemTemplate" Value="{StaticResource AccountCompactTemplate}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.Style>

                            <ListView.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="8,14,0,6">
                                                <Path Data="{StaticResource Icon.Folder}" Stroke="{DynamicResource TextMutedBrush}"
                                                      StrokeThickness="1.5" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}" Margin="8,0,0,0" FontSize="11.5" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                <Border CornerRadius="999" Background="{DynamicResource SurfaceAltBrush}" Margin="8,0,0,0"
                                                        Padding="7,1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ItemCount}" FontSize="10"
                                                               Foreground="{DynamicResource TextMutedBrush}" />
                                                </Border>
                                                <!-- Online-count badge: only visible when at least one account in the group is online. -->
                                                <Border CornerRadius="999" Background="#1A3FB950" Margin="6,0,0,0" Padding="7,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding Items, Converter={StaticResource GroupOnlineCount}, ConverterParameter=vis}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="6" Height="6" Fill="#3FB950" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding Items, Converter={StaticResource GroupOnlineCount}}" FontSize="10"
                                                                   Margin="5,0,0,0" VerticalAlignment="Center"
                                                                   Foreground="#3FB950" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListView.GroupStyle>
                        </ListView>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                                    Visibility="{Binding Store.Accounts.Count, Converter={StaticResource CountZeroToVis}}">
                            <Border Width="56" Height="56" CornerRadius="16" HorizontalAlignment="Center"
                                    Background="{DynamicResource SurfaceAltBrush}">
                                <Path Data="{StaticResource Icon.Users}" Style="{StaticResource IconPath}" Width="26" Height="26"
                                      Stroke="{DynamicResource TextMutedBrush}" />
                            </Border>
                            <TextBlock Text="No accounts yet" HorizontalAlignment="Center" Margin="0,14,0,0"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="Add or import a cookie to begin." HorizontalAlignment="Center" Margin="0,4,0,0"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ==================== RIGHT: DETAIL ==================== -->
            <Grid Grid.Column="2">
                <Border Style="{StaticResource Card}" Visibility="{Binding Selected, Converter={StaticResource InverseNullToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon.Accounts}" Style="{StaticResource IconPath}" Width="30" Height="30"
                              Stroke="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Select an account" Margin="0,14,0,0" HorizontalAlignment="Center"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="Its details and launch options appear here." Margin="0,4,0,0"
                                   FontSize="12" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding Selected, Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <!-- Identity card -->
                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel>
                                    <!-- Favorite / pin toggle: pins the account to the top of its group. -->
                                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Padding="6"
                                            VerticalAlignment="Top" ToolTip="Pin to top of group"
                                            Command="{Binding ToggleFavoriteCommand}" CommandParameter="{Binding Selected}">
                                        <Grid Width="18" Height="18">
                                            <Path Data="{StaticResource Icon.Pin}" Stretch="Uniform"
                                                  Fill="{DynamicResource AccentBrush}"
                                                  Visibility="{Binding Selected.IsFavorite, Converter={StaticResource BoolToVis}}" />
                                            <Path Data="{StaticResource Icon.Pin}" Stretch="Uniform"
                                                  Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.5"
                                                  Visibility="{Binding Selected.IsFavorite, Converter={StaticResource InverseBoolToVis}}" />
                                        </Grid>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                    <Grid Width="60" Height="60">
                                        <Border CornerRadius="16" Background="{DynamicResource SurfaceAltBrush}"
                                                BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1" />
                                        <TextBlock Text="{Binding Selected.Initials}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <Border CornerRadius="16" ClipToBounds="True">
                                            <Image Source="{Binding Selected.ThumbnailUrl, Converter={StaticResource UrlToImage}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                    </Grid>
                                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Selected.DisplayName}" FontSize="17" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="12.5" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource MaskConverter}" StringFormat="@{0}">
                                                    <Binding Path="Selected.Username" />
                                                    <Binding Path="MaskUsernames" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                </DockPanel>

                                <UniformGrid Columns="3" Margin="0,16,0,0">
                                    <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="Presence" Style="{StaticResource Caption}" />
                                            <TextBlock Text="{Binding Selected.Presence}" Margin="0,3,0,0" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{Binding Selected.PresenceColor, Converter={StaticResource HexToBrush}}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="10" Padding="10,8" Margin="3,0">
                                        <StackPanel>
                                            <TextBlock Text="Robux" Style="{StaticResource Caption}" />
                                            <TextBlock Text="{Binding Selected.RobuxDisplay}" Margin="0,3,0,0" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="10" Padding="10,8" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="User ID" Style="{StaticResource Caption}" />
                                            <TextBlock Text="{Binding Selected.UserId}" Margin="0,3,0,0" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Open card -->
                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="OPEN" Style="{StaticResource Caption}" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource GhostButton}" Margin="0,0,5,0"
                                            Command="{Binding OpenBrowserCommand}"
                                            ToolTip="Open this account signed-in in a private Chromium browser">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource Icon.External}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                                            <TextBlock Text="Browser" Margin="7,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Style="{StaticResource GhostButton}" Margin="5,0,0,0"
                                            Command="{Binding OpenAppCommand}"
                                            ToolTip="Open the Roblox app signed-in as this account">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource Icon.Play}" Fill="{DynamicResource TextPrimaryBrush}"
                                                  Stroke="{DynamicResource TextPrimaryBrush}" Width="13" Height="13" Stretch="Uniform" />
                                            <TextBlock Text="Roblox app" Margin="7,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <Button Style="{StaticResource GhostButton}" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                        Command="{Binding OpenProfileCommand}"
                                        ToolTip="Open the public Roblox profile in your default browser">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon.Users}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                                        <TextBlock Text="View profile" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <!-- #29 Inject: run a JS snippet in each selected account's logged-in browser -->
                                <Button Style="{StaticResource GhostButton}" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                        Command="{Binding InjectScriptCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=AccountsList}"
                                        ToolTip="Run a JavaScript snippet in each selected account's signed-in browser">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon.External}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                                        <TextBlock Text="Inject script" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Launch card -->
                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="LAUNCH" Style="{StaticResource Caption}" FontWeight="SemiBold" Margin="0,0,0,12" />

                                <Border CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource SurfaceAltBrush}"
                                        Padding="8" Margin="0,0,0,10"
                                        Visibility="{Binding HasGameInfo, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="40" Height="40" CornerRadius="9" ClipToBounds="True"
                                                Background="{DynamicResource ElevatedBrush}">
                                            <Image Source="{Binding GameIcon, Converter={StaticResource UrlToImage}}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center" MaxWidth="250">
                                            <TextBlock Text="{Binding GameName}" FontWeight="SemiBold" FontSize="12.5"
                                                       TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding GameCreator}" FontSize="11" Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextMutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Place ID" Style="{StaticResource Label}" Margin="0,0,0,5" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding PlaceIdText, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Margin="6,0,0,0" Width="38" Height="38"
                                            Command="{Binding SavePlaceCommand}" ToolTip="Save this Place ID under a name">
                                        <Path Data="{StaticResource Icon.Bookmark}" Style="{StaticResource IconPath}" />
                                    </Button>
                                    <ToggleButton x:Name="SavedPlacesToggle" Grid.Column="2" Style="{StaticResource IconToggle}"
                                                  Margin="6,0,0,0" Width="38" Height="38"
                                                  IsChecked="{Binding SavedPlacesOpen, Mode=TwoWay}" ToolTip="Saved places">
                                        <Path Data="{StaticResource Icon.ChevronDown}" Style="{StaticResource IconPath}" Width="12" Height="12" />
                                    </ToggleButton>
                                    <Button Grid.Column="3" Style="{StaticResource IconButton}" Margin="6,0,0,0" Width="38" Height="38"
                                            Command="{Binding BrowseServersCommand}" ToolTip="Browse servers">
                                        <Path Data="{StaticResource Icon.Servers}" Style="{StaticResource IconPath}" />
                                    </Button>

                                    <Popup PlacementTarget="{Binding ElementName=SavedPlacesToggle}" Placement="Bottom"
                                           IsOpen="{Binding SavedPlacesOpen, Mode=TwoWay}" StaysOpen="False"
                                           AllowsTransparency="True" VerticalOffset="6" HorizontalOffset="-180">
                                        <Border Width="218" Background="{DynamicResource ElevatedBrush}"
                                                BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1"
                                                CornerRadius="{StaticResource RadiusMd}" Padding="4"
                                                TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
                                            <StackPanel>
                                                <TextBlock Margin="8,7" FontSize="11.5" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Text="No saved places yet — press the bookmark button to save the current Place ID.">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SavedPlaces.Count}" Value="0">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl x:Name="SavedPlacesList" ItemsSource="{Binding SavedPlaces}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type models:SavedPlace}">
                                                                <Grid Margin="0,1">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Button Style="{StaticResource MenuRowButton}"
                                                                            Command="{Binding DataContext.ApplySavedPlaceCommand, ElementName=SavedPlacesList}"
                                                                            CommandParameter="{Binding}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,8,0"
                                                                                    VerticalAlignment="Center" ClipToBounds="True"
                                                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                                                    Visibility="{Binding IconUrl, Converter={StaticResource NullToVis}}">
                                                                                <Image Source="{Binding IconUrl, Converter={StaticResource UrlToImage}}"
                                                                                       Stretch="UniformToFill" />
                                                                            </Border>
                                                                            <StackPanel VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Name}" FontSize="12.5" TextTrimming="CharacterEllipsis"
                                                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                                                            <TextBlock Text="{Binding PlaceId}" FontSize="10.5" Margin="0,1,0,0"
                                                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="24" Height="24"
                                                                            Margin="4,0,2,0" VerticalAlignment="Center"
                                                                            Command="{Binding DataContext.RemovePlaceCommand, ElementName=SavedPlacesList}"
                                                                            CommandParameter="{Binding}" ToolTip="Remove saved place">
                                                                        <Path Data="{StaticResource Icon.Close}" Style="{StaticResource IconPath}" Width="9" Height="9" />
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <TextBlock Text="Job ID or private-server link (optional — Launch joins it automatically)" Style="{StaticResource Label}" Margin="0,0,0,5" />
                                <TextBox Text="{Binding JobIdText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                                <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                        Command="{Binding LaunchCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=AccountsList}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon.Play}" Fill="{DynamicResource OnAccentBrush}"
                                              Stroke="{DynamicResource OnAccentBrush}" Width="14" Height="14" Stretch="Uniform" />
                                        <TextBlock Text="Launch" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                        Command="{Binding ShuffleJoinCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=AccountsList}"
                                        ToolTip="Join a random non-full public server">
                                    <TextBlock Text="Smart Join (random server)" />
                                </Button>

                                <!-- #29 Power-Tools: server-selection launches -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch"
                                            Command="{Binding PingJoinCommand}"
                                            CommandParameter="{Binding SelectedItems, ElementName=AccountsList}"
                                            ToolTip="Join the lowest-ping public server for this place">
                                        <TextBlock Text="Ping Join" HorizontalAlignment="Center" />
                                    </Button>
                                    <Button Grid.Column="2" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch"
                                            Command="{Binding ServerHopCommand}"
                                            CommandParameter="{Binding SelectedItems, ElementName=AccountsList}"
                                            ToolTip="Jump to a fresh random server, different from the last hop">
                                        <TextBlock Text="Server Hop" HorizontalAlignment="Center" />
                                    </Button>
                                    <Button Grid.Column="4" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch"
                                            Command="{Binding SquadJoinCommand}"
                                            CommandParameter="{Binding SelectedItems, ElementName=AccountsList}"
                                            ToolTip="Land the whole selection in one server with room for everyone">
                                        <TextBlock Text="Squad" HorizontalAlignment="Center" />
                                    </Button>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="0,14" />

                                <TextBlock Text="Follow a user into their game" Style="{StaticResource Label}" Margin="0,0,0,5" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding FollowText, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Width="90"
                                            Command="{Binding FollowCommand}"
                                            CommandParameter="{Binding SelectedItems, ElementName=AccountsList}">
                                        <TextBlock Text="Follow" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Details card -->
                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="DETAILS" Style="{StaticResource Caption}" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Alias" Style="{StaticResource Label}" Margin="0,0,0,5" />
                                <TextBox Text="{Binding Selected.Alias, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,10" />
                                <TextBlock Text="Description" Style="{StaticResource Label}" Margin="0,0,0,5" />
                                <TextBox Style="{StaticResource TextArea}" Text="{Binding Selected.Description, UpdateSourceTrigger=LostFocus}"
                                         MinHeight="70" Margin="0,0,0,10" />

                                <TextBlock Text="Group" Style="{StaticResource Label}" Margin="0,0,0,5" />
                                <ComboBox ItemsSource="{Binding GroupOptions}" SelectedItem="{Binding SelectedGroupOption, Mode=TwoWay}"
                                          Margin="0,0,0,12" ToolTip="Pick a group or create a new one" />

                                <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                        Command="{Binding SaveDetailsCommand}">
                                    <TextBlock Text="Save details" />
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Actions row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource GhostButton}" Command="{Binding CopyCookieCommand}" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Icon.Copy}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                                    <TextBlock Text="Copy cookie" Margin="7,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Style="{StaticResource DangerButton}" Width="110"
                                    Command="{Binding RemoveCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=AccountsList}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Icon.Trash}" Stroke="{DynamicResource DangerBrush}" StrokeThickness="1.6"
                                          Width="15" Height="15" Stretch="Uniform" />
                                    <TextBlock Text="Remove" Margin="7,0,0,0" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
