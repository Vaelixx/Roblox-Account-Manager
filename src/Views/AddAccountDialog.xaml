<Window x:Class="RobloxAccountManager.Views.AddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ram="clr-namespace:RobloxAccountManager"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Width="500" SizeToContent="Height" ShowInTaskbar="False">
    <Border x:Name="Root" Margin="18" CornerRadius="{StaticResource RadiusLg}"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1"
            Effect="{StaticResource ShadowSoft}" RenderTransformOrigin="0.5,0.5"
            TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <Border Width="34" Height="34" CornerRadius="9" Background="{DynamicResource AccentSoftBrush}">
                    <Path Data="{StaticResource Icon.Plus}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.9"
                          Width="16" Height="16" Stretch="Uniform" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Add account" Style="{StaticResource DisplayText}" FontSize="16" />
                </StackPanel>
            </StackPanel>
            <TextBlock Grid.Row="1" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,6,0,14"
                       Text="Paste the account's .ROBLOSECURITY cookie. It's checked against Roblox before it's added." />

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="Cookie" Style="{StaticResource Label}" VerticalAlignment="Center" />
                    <Button x:Name="PasteBtn" HorizontalAlignment="Right" Style="{StaticResource IconButton}"
                            Width="Auto" Height="26" Padding="8,0" Click="Paste_Click" ToolTip="Paste from clipboard">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.Copy}" Style="{StaticResource IconPath}" Width="13" Height="13" />
                            <TextBlock Text="Paste" Margin="6,0,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Button>
                </Grid>
                <Border Grid.Row="1" CornerRadius="{StaticResource RadiusMd}" Height="104"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1">
                    <TextBox x:Name="CookieBox" Background="Transparent" BorderThickness="0"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="102"
                             VerticalContentAlignment="Top" Padding="12,9"
                             VerticalScrollBarVisibility="Auto" FontFamily="{StaticResource MonoFont}"
                             FontSize="12" TextChanged="Cookie_Changed" />
                </Border>
            </Grid>

            <!-- status line -->
            <Border Grid.Row="3" x:Name="StatusBar" Margin="0,12,0,0" CornerRadius="{StaticResource RadiusSm}"
                    Padding="10,8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Path x:Name="StatusIcon" Width="15" Height="15" Stretch="Uniform" StrokeThickness="1.8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText" Margin="9,0,0,0" FontSize="12.5" VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelBtn" Style="{StaticResource GhostButton}" Content="Cancel"
                        Width="104" Margin="0,0,10,0" Click="Cancel_Click" />
                <Button x:Name="AddBtn" Style="{StaticResource PrimaryButton}" Content="Add account"
                        Width="140" Click="Add_Click" IsDefault="True" />
            </StackPanel>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX"
                                     From="0.96" To="1" Duration="0:0:0.22">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY"
                                     From="0.96" To="1" Duration="0:0:0.22">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
