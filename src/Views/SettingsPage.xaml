<UserControl x:Class="RobloxAccountManager.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel Margin="24,8,24,24" MaxWidth="720" HorizontalAlignment="Left">

            <!-- ===== Launch ===== -->
            <TextBlock Text="Launch" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="4" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Multi-instance" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Run more than one Roblox client at the same time." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding EnableMultiInstance}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Unlock launches started outside the app" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Clears Roblox's per-client lock as well, so the Play button on roblox.com, the Roblox home screen and Discord invites open their own client instead of taking over the one already running."
                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding CloseSingletonEvent}" IsEnabled="{Binding EnableMultiInstance}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Manage external clients" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Let Anti-AFK, the RAM monitor and the window grid also see clients this app did not launch."
                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding AdoptExternalClients}" IsEnabled="{Binding EnableMultiInstance}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <StackPanel Margin="16,14">
                        <TextBlock Text="{Binding MultiInstanceStatus}" Style="{StaticResource Caption}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="Fix multi-instance now" Command="{Binding FixMultiInstanceCommand}"
                                    Style="{StaticResource GhostButton}" />
                            <Button Content="Restart as administrator" Command="{Binding RestartElevatedCommand}"
                                    Style="{StaticResource GhostButton}" Margin="10,0,0,0"
                                    Visibility="{Binding ShowElevatePrompt, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Close previous client" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="When relaunching an account, close its earlier window first." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding AutoCloseLastProcess}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Launch delay" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Seconds to wait between each account when launching several." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <TextBox Width="90" HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Text="{Binding AccountJoinDelay, UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Smart Join picks emptiest server" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Otherwise a random non-full public server is chosen." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding ShuffleLowestServer}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Server scan pages" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="How many pages (×100 servers) Smart Join scans." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <TextBox Width="90" HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Text="{Binding ShufflePageCount, UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Performance ===== -->
            <TextBlock Text="Performance" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="4" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Unlock FPS" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Writes a ClientAppSettings FPS cap before launching." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding UnlockFps}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="FPS cap" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Target frame rate when Unlock FPS is on." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <TextBox Width="90" HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Text="{Binding MaxFps, UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Live data ===== -->
            <TextBlock Text="Live data" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="4" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Show avatars" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Load headshot thumbnails for each account." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding ShowThumbnails}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Show presence" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Display online / in-game status." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding ShowPresence}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Show Robux" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Fetch each account's Robux balance." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding ShowRobux}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Interface ===== -->
            <TextBlock Text="Interface" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="4" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Hide usernames" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Mask usernames for screenshots / streaming." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding HideUsernames}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Close to tray" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Closing the window minimizes to the system tray instead of quitting. Double-click the tray icon to reopen; right-click for Exit." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding MinimizeToTray}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Appearance (#30) ===== -->
            <TextBlock Text="Appearance" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="4" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Theme preset -->
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,180,0">
                            <TextBlock Text="Theme preset" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Pick a built-in palette. Editing a swatch below switches to a custom copy." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <ComboBox Width="170" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  ItemsSource="{Binding ThemePresets}" SelectedItem="{Binding ThemeName}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />

                    <!-- Editable colour swatches -->
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Theme colours" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Edit any swatch as #RRGGBB. A red outline marks a value that is not yet valid." Style="{StaticResource Caption}" Margin="0,3,0,10" />
                        <ItemsControl ItemsSource="{Binding ThemeColors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="4"
                                                Background="{Binding Hex, Converter={StaticResource HexToBrush}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource HairlineStrongBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,10,0">
                                            <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12.5" />
                                            <TextBlock Text="{Binding Group}" Style="{StaticResource Caption}" FontSize="10.5" />
                                        </StackPanel>
                                        <TextBox Grid.Column="2" Text="{Binding Hex, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="100" VerticalAlignment="Center" FontFamily="Consolas" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Reset to preset" Style="{StaticResource GhostButton}"
                                Command="{Binding ResetThemeCommand}" HorizontalAlignment="Left" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />

                    <!-- Account view mode -->
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,180,0">
                            <TextBlock Text="Account list layout" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Card shows avatars and details; Compact is a dense one-line-per-account list." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <ComboBox Width="170" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  ItemsSource="{Binding ViewModes}" SelectedItem="{Binding AccountViewMode}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />

                    <!-- Language -->
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,180,0">
                            <TextBlock Text="Language" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Interface language. Some strings apply after the next window open." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <ComboBox Width="170" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  ItemsSource="{Binding Languages}" SelectedItem="{Binding Language}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Notifications (#30) ===== -->
            <TextBlock Text="Notifications" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="4" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="In-app toasts" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Show brief pop-up notifications in the corner of the window." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding EnableToasts}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Notify on launch" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Raise a toast whenever a client finishes launching." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding ToastOnLaunch}" IsEnabled="{Binding EnableToasts}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <Grid Margin="16,14">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                            <TextBlock Text="Notify on crash" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Raise a toast when a tracked client crashes or is closed unexpectedly." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding ToastOnCrash}" IsEnabled="{Binding EnableToasts}" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="16,0" />
                    <!-- Discord webhook (rich embeds) -->
                    <StackPanel Margin="16,14">
                        <TextBlock Text="Discord webhook" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Send rich embed messages to a Discord channel on connect / disconnect / reconnect."
                                   Style="{StaticResource Caption}" Margin="0,3,0,8" />
                        <TextBox Text="{Binding DiscordWebhookUrl, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="https://discord.com/api/webhooks/..." />
                        <Grid Margin="0,14,0,0">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                                <TextBlock Text="Embed on connect" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="Post an embed each time an account launches / connects." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                            </StackPanel>
                            <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding NotifyOnConnect}" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,120,0">
                                <TextBlock Text="Embed on disconnect / reconnect" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="Post embeds when a tracked client closes and when it auto-rejoins." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                            </StackPanel>
                            <CheckBox Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding NotifyOnCrash}" />
                        </Grid>
                        <Button Content="Send test embed" Command="{Binding TestWebhookCommand}"
                                Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,14,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Browser ===== -->
            <TextBlock Text="Browser" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.External}" Style="{StaticResource IconPath}" Width="16" Height="16"
                              Stroke="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ChromiumStatus}" Margin="10,0,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12.5" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding DownloadChromiumCommand}"
                            Content="{Binding ChromiumButtonText}" Width="200" HorizontalAlignment="Left" Margin="0,14,0,0" />
                </StackPanel>
            </Border>

            <TextBlock Text="Plugins" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.External}" Style="{StaticResource IconPath}" Width="16" Height="16"
                              Stroke="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PluginStatus}" Margin="10,0,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12.5" VerticalAlignment="Center" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Plugins}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Version, StringFormat=' v{0}'}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Error}" Foreground="{DynamicResource DangerBrush}"
                                                   FontSize="11.5" TextWrapping="Wrap" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding ReloadPluginsCommand}"
                                Content="Reload plugins" Width="150" HorizontalAlignment="Left" />
                        <Button Style="{StaticResource GhostButton}" Command="{Binding OpenPluginsFolderCommand}" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon.Folder}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                                <TextBlock Text="Open plugins folder" Margin="7,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Security ===== -->
            <TextBlock Text="Security" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Lock}" Style="{StaticResource IconPath}" Width="16" Height="16"
                              Stroke="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PasswordStatus}" Margin="10,0,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12.5" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding SetPasswordCommand}" Width="180">
                            <TextBlock Text="Set / change password" />
                        </Button>
                        <Button Style="{StaticResource GhostButton}" Command="{Binding RemovePasswordCommand}" Margin="10,0,0,0" Width="150"
                                Visibility="{Binding HasMasterPassword, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Remove password" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Diagnostics ===== -->
            <TextBlock Text="Diagnostics" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{Binding DiagnosticsStatus}" Style="{StaticResource Caption}" TextWrapping="Wrap" />

                    <ItemsControl ItemsSource="{Binding HealthChecks}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StatusGlyph}" FontFamily="Consolas" FontWeight="Bold" Width="24">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Ok}" Value="False">
                                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="24,2,0,0" />
                                        <TextBlock Text="{Binding Hint}" Foreground="{DynamicResource WarningBrush}" FontSize="11.5"
                                                   TextWrapping="Wrap" Margin="24,3,0,0"
                                                   Visibility="{Binding HasHint, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <WrapPanel Margin="0,8,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding RunHealthCheckCommand}"
                                Content="Run self-check" Width="150" IsEnabled="{Binding HealthRunning, Converter={StaticResource InverseBool}}" />
                        <Button Style="{StaticResource GhostButton}" Command="{Binding OpenDiagnosticsCommand}" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon.Folder}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                                <TextBlock Text="Open log folder" Margin="7,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" Command="{Binding ClearDiagnosticsCommand}"
                                Content="Clear log" Margin="10,0,0,0" />
                    </WrapPanel>

                    <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="0,16,0,14" />

                    <TextBlock Text="Client windows" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Acts on every running Roblox client, including ones started from the website."
                               Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,3,0,10" />
                    <WrapPanel>
                        <Button Style="{StaticResource GhostButton}" Command="{Binding ArrangeWindowsCommand}" Content="Arrange in a grid" />
                        <Button Style="{StaticResource GhostButton}" Command="{Binding MinimizeClientsCommand}" Content="Minimize all" Margin="10,0,0,0" />
                        <Button Style="{StaticResource GhostButton}" Command="{Binding RestoreClientsCommand}" Content="Restore all" Margin="10,0,0,0" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ===== About ===== -->
            <TextBlock Text="About" Style="{StaticResource DisplayText}" FontSize="15" Margin="2,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="18">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Roblox Account Manager" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding AppVersion}" Style="{StaticResource Caption}" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Style="{StaticResource GhostButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Command="{Binding OpenDataFolderCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.Folder}" Style="{StaticResource IconPath}" Width="15" Height="15" />
                            <TextBlock Text="Open data folder" Margin="7,0,0,0" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
