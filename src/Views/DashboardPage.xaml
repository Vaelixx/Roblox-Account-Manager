<UserControl x:Class="RobloxAccountManager.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:RobloxAccountManager.Models">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============ Header ============ -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="LIVE STATUS" Style="{StaticResource Label}" />
                <TextBlock Text="Real-time presence across every account"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{Binding LastUpdated, StringFormat='Updated {0}'}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button Content="Refresh now" Command="{Binding RefreshCommand}"
                        Style="{StaticResource GhostButton}" />
            </StackPanel>
        </Grid>

        <!-- ============ Summary counters ============ -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="0,20,0,0">
            <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="TOTAL" Style="{StaticResource Label}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Total}" FontSize="30" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="3,0,3,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#3FB950" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="ONLINE" Style="{StaticResource Label}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Online}" FontSize="30" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="3,0,3,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#7B61FF" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="IN GAME" Style="{StaticResource Label}" />
                    </StackPanel>
                    <TextBlock Text="{Binding InGame}" FontSize="30" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="3,0,3,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#E3B341" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="IN STUDIO" Style="{StaticResource Label}" />
                    </StackPanel>
                    <TextBlock Text="{Binding InStudio}" FontSize="30" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#63636C" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="OFFLINE" Style="{StaticResource Label}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Offline}" FontSize="30" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ============ Economy strip ============ -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="3" Margin="0,10,0,0">
            <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="TOTAL ROBUX" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding TotalRobux, StringFormat='{}{0:N0}'}" FontSize="24" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="3,0,3,0">
                <StackPanel>
                    <TextBlock Text="TOTAL RAP" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding TotalRap, StringFormat='{}{0:N0}'}" FontSize="24" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="PREMIUM" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding PremiumCount}" FontSize="24" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ============ Per-account live list ============ -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Account}">
                            <Border Padding="14,10" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding PresenceColor}"
                                             VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <TextBlock Grid.Column="1"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource MaskConverter}">
                                                <Binding Path="DisplayNameOrUser" />
                                                <Binding Path="DataContext.MaskUsernames" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#7B61FF" CornerRadius="4" Padding="5,1" Margin="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsPremium, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="PREMIUM" Foreground="White" FontSize="9" FontWeight="Bold" />
                                        </Border>
                                        <TextBlock Text="{Binding RobuxDisplay, StringFormat='R$ {0}'}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,14,0" />
                                        <TextBlock Text="{Binding RapDisplay, StringFormat='RAP {0}'}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,14,0" />
                                        <TextBlock Text="{Binding Presence}" Foreground="{Binding PresenceColor}"
                                                   VerticalAlignment="Center" FontSize="12" FontWeight="Medium"
                                                   MinWidth="58" TextAlignment="Right" />
                                        <Border Margin="6,0,0,0" Padding="4,0" CornerRadius="3" VerticalAlignment="Center"
                                                Background="{DynamicResource AccentBrush}" ToolTip="{Binding SubPlaceTip}"
                                                Visibility="{Binding IsSubPlace, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="SUB" FontSize="9" FontWeight="Bold" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
