<UserControl x:Class="RobloxAccountManager.Views.FriendsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:RobloxAccountManager.Models">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============ Header ============ -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="FRIENDS" Style="{StaticResource Label}" />
            <TextBlock Text="See who's online and jump straight into a friend's game"
                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,2,0,0" />
        </StackPanel>

        <!-- ============ Toolbar: account picker · refresh · search ============ -->
        <Grid Grid.Row="1" Margin="0,18,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Account" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,8,0" />
                <ComboBox Width="220" VerticalAlignment="Center"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Account}">
                            <TextBlock Text="{Binding DisplayNameOrUser}" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"
                        Style="{StaticResource GhostButton}" Margin="10,0,0,0" />
            </StackPanel>

            <Grid Width="220" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Search friends…" IsHitTestVisible="False"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           Foreground="{DynamicResource TextMutedBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>

        <!-- ============ Friends list ============ -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Friends}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Friend}">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- avatar + presence dot -->
                                    <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,12,0">
                                        <Border CornerRadius="22" ClipToBounds="True"
                                                Background="{DynamicResource SurfaceBrush}">
                                            <Image Source="{Binding HeadshotUrl, Converter={StaticResource UrlToImage}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <Ellipse Width="13" Height="13" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                 Fill="{Binding PresenceColor, Converter={StaticResource HexToBrush}}"
                                                 Stroke="{DynamicResource SurfaceBrush}" StrokeThickness="2" />
                                    </Grid>

                                    <!-- name + status -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayNameOrUser}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                            <TextBlock Text="{Binding AtUsername}" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding StatusLine}" FontSize="11"
                                                       Foreground="{Binding PresenceColor, Converter={StaticResource HexToBrush}}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- actions -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Join"
                                                Command="{Binding DataContext.JoinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PrimaryButton}"
                                                Visibility="{Binding CanJoin, Converter={StaticResource BoolToVis}}"
                                                ToolTip="Follow this friend into their game" />
                                        <Button Content="Profile"
                                                Command="{Binding DataContext.OpenProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                                                ToolTip="Open this friend's Roblox profile in the browser" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- empty state -->
            <TextBlock Text="{Binding EmptyText}" HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,48,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Visibility="{Binding Friends.Count, Converter={StaticResource CountZeroToVis}}" />
        </Grid>
    </Grid>
</UserControl>
