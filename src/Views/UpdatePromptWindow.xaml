<Window x:Class="RobloxAccountManager.Views.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update available"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="560" Height="500"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource CanvasBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource UiFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{DynamicResource WindowBackdropBrush}"
            BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1">
        <Grid Margin="28,24,28,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource InfoBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Update available" Margin="9,0,0,0" VerticalAlignment="Center"
                           FontFamily="{StaticResource DisplayFont}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- Version transition -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
                <Border CornerRadius="999" Padding="10,3"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="1">
                    <TextBlock x:Name="CurrentVersionText" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Border>
                <TextBlock Text="→" Margin="10,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <Border CornerRadius="999" Padding="10,3"
                        Background="{DynamicResource AccentSoftBrush}"
                        BorderBrush="{DynamicResource HairlineStrongBrush}" BorderThickness="1">
                    <TextBlock x:Name="NewVersionText" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </Border>
            </StackPanel>

            <!-- Meta: publish date · download size · source -->
            <TextBlock x:Name="MetaText" Grid.Row="2" Margin="0,8,0,12" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />

            <!-- Release notes -->
            <Border Grid.Row="3" CornerRadius="10"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                    <StackPanel x:Name="NotesPanel" Margin="0,0,6,4" />
                </ScrollViewer>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="4" Margin="0,16,0,0">
                <Button Style="{StaticResource GhostButton}" Content="View on GitHub ↗"
                        HorizontalAlignment="Left" Click="ViewOnGitHub_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource GhostButton}" Content="Later"
                            Margin="0,0,10,0" Click="Later_Click" />
                    <Button Style="{StaticResource PrimaryButton}" Content="Update now"
                            Click="UpdateNow_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
